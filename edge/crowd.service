[Unit]
Description=Crowd Edge Agent
After=network-online.target

[Service]
Type=simple

EnvironmentFile=-/home/pi/edge/.env

WorkingDirectory=/tmp

ExecStartPre=/usr/local/bin/start.sh
ExecStart=/usr/bin/python3 -u /home/pi/edge/agent/main.py

Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target